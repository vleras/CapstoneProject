    {
      "name": "3138bfbb",
      "displayName": "Certification Status Summary of Gold Metadata",
      "queryLines": [
        "SELECT COUNT(*) AS passed_records\n",
        "FROM metadata_governance.gold.gold_certified_metadata_final\n",
        "WHERE certification_status = 'PASS'"
      ]
    },
    {
      "name": "c568bffa",
      "displayName": "Tables Needing Review Based on Compliance Threshold",
      "queryLines": [
        "SELECT COUNT(DISTINCT name) AS `Tables Requiring Attention`\r\n",
        "FROM metadata_governance.gold.gold_quality_metrics_final\r\n",
        "WHERE level = 'table' \r\n",
        "  AND CAST(compliance_score AS DOUBLE) < :Compliance_Threshold"
      ],
      "parameters": [
        {
          "displayName": "Compliance_Threshold",
          "keyword": "Compliance_Threshold",
          "dataType": "STRING",
          "defaultSelection": {
            "values": {
              "dataType": "STRING",
              "values": [
                {
                  "value": "100"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "ab07f215",
      "displayName": "Data Quality Rule Compliance Overview",
      "queryLines": [
        "SELECT \r\n",
        "  name AS `Table Name`, \r\n",
        "  passed AS `Passed Rules`, \r\n",
        "  failed AS `Failed Rules`, \r\n",
        "  compliance_score AS `Compliance Score (%)`\r\n",
        "FROM metadata_governance.gold.gold_quality_metrics_final\r\n",
        "WHERE level = 'table' AND compliance_score < 100\r\n",
        "ORDER BY compliance_score ASC"
      ]
    },
    {
      "name": "96ee9514",
      "displayName": "structural compliance",
      "queryLines": [
        "SELECT 'Perfect Match (10 Columns)' AS `Structural Status`, 13 AS `Number of Tables`\r\n",
        "UNION ALL\r\n",
        "SELECT 'Structural Anomaly (<10 Columns)' AS `Structural Status`, 1 AS `Number of Tables`"
      ]
    },
    {
      "name": "5a5285ce",
      "displayName": "Gold Data Quality Insights Summary",
      "queryLines": [
        "SELECT * FROM metadata_governance.gold.gold_quality_metrics_final;"
      ]
    },
    {
      "name": "2b00a722",
      "displayName": "Flaws_ingestion_governance",
      "queryLines": [
        "SELECT \r\n",
        "  name AS table_name,\r\n",
        "  'Ingestion Flaw (Pipeline)' AS flaw_type,\r\n",
        "  failed AS flaw_count\r\n",
        "FROM metadata_governance.gold.gold_quality_metrics_final\r\n",
        "WHERE level = 'table'\r\n",
        "UNION ALL\r\n",
        "SELECT \r\n",
        "  table_name,\r\n",
        "  'Governance Flaw (Documentation)' AS flaw_type,\r\n",
        "  COUNT(*) AS flaw_count\r\n",
        "FROM metadata_governance.gold.gold_certified_metadata_final\r\n",
        "WHERE column_desc IS NULL OR data_steward IS NULL\r\n",
        "GROUP BY table_name"
      ]
    }
  ],
