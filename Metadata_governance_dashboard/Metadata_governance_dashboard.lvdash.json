                  "datasetName": "171f5599",
                  "fields": [
                    {
                      "name": "avg(compliance_score)",
                      "expression": "AVG(`compliance_score`)"
                    }
                  ],
                  "filters": [
                    {
                      "expression": "`level` IN ('catalog')"
                    }
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
